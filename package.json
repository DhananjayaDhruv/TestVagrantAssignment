
{
  "name": "advanced-enterprise-playwright-framework",
  "version": "2.0.0",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "smoke": "playwright test --grep @smoke",
    "regression": "playwright test --grep @regression",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:report": "npm run allure:generate && allure open allure-report"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.53.0",
    "ajv": "^8.17.1",
    "allure-playwright": "^3.3.3",
    "dotenv": "^16.5.0",
    "typescript": "^5.0.0",
    "winston": "^3.17.0"
  }
}
